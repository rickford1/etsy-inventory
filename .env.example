ETSY_API_KEY=your_api_key_here
ETSY_SHARED_SECRET=your_shared_secret_here
ETSY_REDIRECT_URI=http://localhost:3003/callback
ETSY_SHOP_ID=your_shop_id_here

# Optional: Meta ad analytics (leave blank to skip the Marketing/ROAS features)
META_ACCESS_TOKEN=your_meta_access_token_here
META_AD_ACCOUNT_ID=act_XXXXXXXXXX

# Display name shown in the dashboard sidebar
SHOP_NAME=My Etsy Shop

# Starter materials + bill-of-materials to seed on a fresh database.
#   3d-printing = filament + packaging preset (default)
#   none        = start empty and define your own via the CLI
SEED_PRESET=none
